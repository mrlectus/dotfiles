#System
##########################
##########################

# terminal emulator
super + Return
    kitty
# terminal emulator with tmux
super + shift + Return
    sh /home/brown/my_tmux	


# window launcher
super + shift + d
    rofi -show window -window-thumbnail -show-icons -theme sidebar -theme-str 

# Power menu
super + p
    rofi -show power-menu -location 2 --yoffset 30 -xoffset 10 -width 15 -columns 1 -lines 6 -modi power-menu:~/.config/rofi/rofi-power-menu 

# make sxhkd reload its configuration files:
super + Escape
	pkill -USR1 -x sxhkd; dunstify 'sxhkd' 'Reloaded config'

# File manager
super + a 
  lf /home/brown

# Fullsreen/Region Screenshot:
#  
Print + {_,shift}
	{mate-screenshot, mate-screenshot -a}

# quit/restart bspwm
super + {q,r}
	bspc {quit,wm -r}

# close and kill
super + {_,shift + }w
	bspc node -{c,k}

# close 
super + c 
	bspc node -c

# locksereen
super + x
  betterlockscreen -l dim
  
# alternate between the tiled and monocle layout
super + m
	bspc desktop -l next

# send the newest marked node to the newest preselected node

super + y
	bspc node newest.marked.local -n newest.!automatic.local

# swap the current node and the biggest window
super + b 
	bspc node -s biggest.window

# state/flags

# set the window state
super + {t,shift + t,s,f}
	bspc node -t {tiled && xdo show -N Polybar,pseudo_tiled,floating,fullscreen && xdo hide -N Polybar}

super + ctrl + {m,x,y,z}
	bspc node -g {marked,locked,sticky,private}

# focus/swap

# focus the node in the given direction
super + {_,shift + }{Left,Down,Up,Right}
	bspc node -{f,s} {west,south,north,east}

# focus the node for the given path jump
super + {p,b,comma,period}
	bspc node -f @{parent,brother,first,second}

# focus the next/previous window in the current desktop
super + {_,shift + }Tab
	bspc node -f {next,prev}.local.!hidden.window

# focus the next/previous desktop in the current monitor
super + bracket{left,right}
	bspc desktop -f {prev,next}.local

# focus the last node/desktop
super + {grave,Tab}
	bspc {node,desktop} -f last

# focus the older or newer node in the focus history
super + {o,i}
	bspc wm -h off; \
	bspc node {older,newer} -f; \
	bspc wm -h on

# focus or send to the given desktop
super + {_,shift + }{1-9,0}
	bspc {desktop -f,node -d} '^{1-9,10}'

# preselect
#
super + d
	/usr/local/bin/rofi -show drun -display-drun 'App launcher'

# Config
alt + 1
  ~/.config/rofi/scripts/config

# Search
alt + 3
  ~/.config/rofi/scripts/search

# Sites
alt + 2
  ~/.config/rofi/scripts/site

# preselect the direction
super + alt + {Left,Down,Up,Right}
	bspc node -p {west,south,north,east}

# preselect the direction
super + {backslash, minus}
	bspc node -p {east,south}

# preselect the ratio
super + alt + {1-9}
	bspc node -o 0.{1-9}

# cancel the preselection for the focused node
super + alt + space
	bspc node -p cancel

# cancel the preselection for the focused desktop
super + ctrl + shift + space
	bspc query -N -d | xargs -I id -n 1 bspc node id -p cancel

#
# move/resize
# Move floating windows
alt + {Left,Right,Up,Down}
    xdo move {-x -30,-x +30,-y -30,-y +30}

# Resize floating windows
alt + shift + {Left,Right,Up,Down}
    xdo resize {-w -20,-w +20,-h -20,-h +20}

# expand a window by moving one of its side outward
super + {h,j,k,l}
  bspc node -z {left -20 0 || bspc node -z right -20 0, \
                bottom 0 20 || bspc node -z top 0 20,\
                top 0 -20 || bspc node -z bottom 0 -20,\
                right 20 0 || bspc node -z left 20 0}
#Volume Control
XF86AudioLowerVolume
	amixer set Master 5%-
XF86AudioRaiseVolume
	amixer set Master 5%+
XF86AudioMute
  amixer set Master toggle

#Brightness control
XF86MonBrightnessDown
	xbacklight -dec 5
XF86MonBrightnessUp
	xbacklight -inc 5

# mouse control
super + button{1-3}
  bspc pointer -g {move,resize_side,resize_corner}

super + !button{1-3}
  bspc pointer -t %i %i

super + @button{1-3}
  bspc pointer -u

# scripts
super + slash 
  bash /home/brown/.config/sxhkd/script.sh

